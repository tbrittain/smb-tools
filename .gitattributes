# Normalize all text files to LF in the repo and on checkout
* text=auto eol=lf

# Go
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf

# Web
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Docs / config
*.md text eol=lf
*.toml text eol=lf
*.env text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Windows-specific: keep CRLF for files that must have it
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.zip binary
*.tar binary
*.gz binary
*.db binary
*.sqlite binary
